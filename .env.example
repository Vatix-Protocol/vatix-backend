# Stellar
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Oracle
# Duration of the resolution challenge window in seconds (positive integer).
# All window boundary calculations use UTC timestamps.
# Default: 86400 (24 hours). Example values: 3600 = 1 h, 86400 = 24 h, 604800 = 7 days.
ORACLE_CHALLENGE_WINDOW_SECONDS=86400
