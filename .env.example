# =============================================================================
# Vatix Backend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Do NOT commit .env or any file containing real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development          # development | production | test

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/vatix

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Oracle signing keypair (required)
# Generate a fresh keypair with: pnpm generate:keypair
# Never reuse testnet keys in production.
# -----------------------------------------------------------------------------
ORACLE_SECRET_KEY=SAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Admin API guard (required for admin routes)
# Use a long random string, e.g.: openssl rand -hex 32
# -----------------------------------------------------------------------------
ADMIN_TOKEN=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Stellar network (optional — defaults shown)
# -----------------------------------------------------------------------------
# STELLAR_NETWORK=testnet
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# -----------------------------------------------------------------------------
# Rate limiting (optional — defaults shown)
# All durations are in milliseconds.
# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=60000       # Global window
# RATE_LIMIT_MAX=100               # Global max requests per window

# RATE_LIMIT_HEAVY_WINDOW_MS=60000 # Heavy-read endpoints window
# RATE_LIMIT_HEAVY_MAX=20          # Heavy-read endpoints max requests

# RATE_LIMIT_WRITE_WINDOW_MS=60000 # Write endpoints window
# RATE_LIMIT_WRITE_MAX=10          # Write endpoints max requests
